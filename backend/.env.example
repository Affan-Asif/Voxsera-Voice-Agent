# ============================================================
# Voice Agent Platform — environment variables
# Copy this file to `.env` and fill in your own keys.
#   cp .env.example .env
# ============================================================

# ---------- Gemini (LLM brain) ----------
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# flash-lite has higher free-tier RPM; change if you have a paid tier
GEMINI_MODEL=gemini-2.5-flash-lite

# ---------- Deepgram (STT + English-accent TTS voices) ----------
# Get one at: https://console.deepgram.com  ($200 free credit)
DEEPGRAM_API_KEY=

# ---------- Sarvam AI (Indian-accent + multilingual TTS voices) ----------
# Get one at: https://dashboard.sarvam.ai  (free tier available)
SARVAM_API_KEY=

# ---------- Twilio (telephony) ----------
# Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your purchased Twilio number in E.164 format, e.g. +14155551234
TWILIO_PHONE_NUMBER=

# ---------- Supabase (call logs, transcripts, business profiles) ----------
# Project settings -> Data API -> URL / service_role secret
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---------- Google OAuth (Calendar + Sheets, per business) ----------
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth Client ID (Web application)
# Authorized redirect URI must be:  {BASE_URL}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Resend (booking-confirmation emails) ----------
# Get one at: https://resend.com/api-keys
RESEND_API_KEY=
# Sender address. `onboarding@resend.dev` works out of the box but can ONLY
# deliver to the email address of the Resend account owner (fine for demos).
# To email anyone, verify a domain in Resend and use e.g. bookings@yourdomain.com
RESEND_FROM=onboarding@resend.dev

# ---------- Server ----------
# Public HTTPS URL of this backend (your ngrok URL), NO trailing slash
# e.g. https://a1b2c3d4.ngrok-free.app
BASE_URL=

# Where the React dashboard runs (used for CORS + OAuth redirect back)
FRONTEND_URL=http://localhost:5173

# Port for uvicorn (informational; pass --port to uvicorn)
PORT=8000
